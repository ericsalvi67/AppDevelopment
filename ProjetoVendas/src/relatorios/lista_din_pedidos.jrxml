<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="projeto_vendas" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fd7e312a-fb9b-4c3d-a9b1-f2848b655f52">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="316"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="677"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="db_projetoVendas"/>
	<parameter name="dataIni" class="java.lang.String"/>
	<parameter name="dataFim" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
		p.id,
	    c.nome cliente,
	    p.data,
	    pr.descricao AS produto,
	    ip.qtde,
	    ip.valor_item
FROM cliente c
JOIN pedido p 
    ON p.cliente_id = c.id
JOIN item_pedido ip 
    ON ip.pedido_id = p.id
JOIN produto pr 
    ON pr.id = ip.produto_id
WHERE TO_DATE(p.data, 'DD/MM/YYYY') >= TO_DATE('$P!{dataIni}', 'DD/MM/YYYY')
  AND TO_DATE(p.data, 'DD/MM/YYYY') <= TO_DATE('$P!{dataFim}', 'DD/MM/YYYY')
order by p.data]]>
	</queryString>
