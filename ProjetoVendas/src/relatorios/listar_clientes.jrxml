	<queryString>
		<![CDATA[select c.id,
			c.nome, 
			c.email, 
			c.cpf, 
			c.telefone, 
			e.cep, 
			e.descricao 
from cliente c
left join cliente_endereco ce on ce.cliente_id = c.id
left join endereco e on e.id = ce.endereco_id]]>
	</queryString>
